+	inode = ilookup(buf->sb, ino);
+	if (inode) {
+		if (zeromount_is_injected_file(inode)) {
+			iput(inode);
+			return 0;
+		}
+		iput(inode);
+	}
+#endif
 	dirent = buf->current_dir;
 	if (__put_user(d_ino, &dirent->d_ino))
 		goto efault;
@@ -269,6 +330,9 @@ SYSCALL_DEFINE3(getdents, unsigned int, fd,
